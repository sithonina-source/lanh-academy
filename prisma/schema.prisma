// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password    String
  role        String   @default("USER") // ADMIN, STAFF, USER
  permissions String?  // Chuỗi JSON: ["COURSES", "ORDERS", "BLOGS"] 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model Course {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  category      String
  instructor    String   @default("Lành Workshop")
  duration      String
  level         String
  lessonsCount  Int      @default(0)
  price         Int
  discountPrice Int?
  discountEndsAt DateTime?
  imageUrl      String
  description   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]
  modules       Module[]
}

model Order {
  id          String   @id @default(cuid())
  userId      String
  courseId    String
  status      String   @default("PENDING") // PENDING, PAID, COMPLETED
  totalAmount Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  course      Course   @relation(fields: [courseId], references: [id])
}

model Blog {
  id          String   @id @default(cuid())
  title       String
  excerpt     String
  content     String
  tag         String
  imageUrl    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Module {
  id        String   @id @default(cuid())
  title     String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  videoUrl    String
  documentUrl String?
  moduleId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}
